#!/bin/sh
# cdpx host launcher. Release automation replaces the digest placeholder.
set -eu

LAUNCHER_VERSION="0.1.0"
DEFAULT_IMAGE="ghcr.io/inem0o/cdpx@sha256:__CDPX_IMAGE_DIGEST__"
INSTALL_URL="https://inem0o.github.io/cdpx/install"

die() {
    printf 'cdpx: %s\n' "$*" >&2
    exit 1
}

usage_error() {
    printf 'cdpx: %s\n' "$*" >&2
    exit 2
}

json_escape() {
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

canonical_directory() {
    (CDPATH='' cd -- "$1" && pwd -P)
}

workspace_root() {
    if command -v git >/dev/null 2>&1 && git rev-parse --show-toplevel >/dev/null 2>&1; then
        canonical_directory "$(git rev-parse --show-toplevel)"
    else
        pwd -P
    fi
}

sha256_text() {
    if command -v sha256sum >/dev/null 2>&1; then
        printf '%s' "$1" | sha256sum | awk '{print $1}'
    elif command -v shasum >/dev/null 2>&1; then
        printf '%s' "$1" | shasum -a 256 | awk '{print $1}'
    else
        die "sha256sum or shasum is required"
    fi
}

docker_ready() {
    command -v docker >/dev/null 2>&1 || die "Docker is required"
    docker info >/dev/null 2>&1 || die "Docker daemon is unavailable"
}

image_ref() {
    if [ -n "${CDPX_IMAGE_REF:-}" ]; then
        printf '%s\n' "$CDPX_IMAGE_REF"
        return
    fi
    case "$DEFAULT_IMAGE" in
        *"__CDPX_IMAGE_DIGEST__"*)
            usage_error "this source launcher is unreleased; set CDPX_IMAGE_REF=cdpx-runtime:dev"
            ;;
    esac
    printf '%s\n' "$DEFAULT_IMAGE"
}

container_exists() {
    docker container inspect "$CONTAINER_NAME" >/dev/null 2>&1
}

container_running() {
    [ "$(docker inspect --format '{{.State.Running}}' "$CONTAINER_NAME" 2>/dev/null || true)" = "true" ]
}

compile_plan() {
    mkdir -p "$PLAN_DIR" "$STATE_DIR/home"
    chmod 700 "$STATE_DIR" "$PLAN_DIR" "$STATE_DIR/home"
    if container_running; then
        docker exec \
            --workdir "$WORKSPACE" \
            "$CONTAINER_NAME" \
            python -m cdpx.runtime_config compile \
            --root "$WORKSPACE" --output "$PLAN_DIR" >/dev/null
    else
        docker run --rm \
            --user "$USER_ID:$GROUP_ID" \
            --mount "type=bind,source=$WORKSPACE,target=$WORKSPACE" \
            --workdir "$WORKSPACE" \
            --entrypoint python \
            "$IMAGE_REF" \
            -m cdpx.runtime_config compile \
            --root "$WORKSPACE" --output "$PLAN_DIR" >/dev/null
    fi
}

container_active_count() {
    if ! container_running; then
        printf '0\n'
        return
    fi
    docker exec "$CONTAINER_NAME" python -m cdpx.runtime active-count 2>/dev/null || printf '0\n'
}

remove_runtime_container() {
    if container_exists; then
        docker stop --time 15 "$CONTAINER_NAME" >/dev/null 2>&1 || true
        docker rm --force "$CONTAINER_NAME" >/dev/null 2>&1 || true
    fi
}

ensure_runtime() {
    fingerprint=$(sed -n '1p' "$PLAN_DIR/fingerprint")
    current_image=""
    current_fingerprint=""
    if container_exists; then
        current_image=$(docker inspect --format '{{ index .Config.Labels "io.cdpx.image" }}' \
            "$CONTAINER_NAME" 2>/dev/null || true)
        current_fingerprint=$(docker inspect \
            --format '{{ index .Config.Labels "io.cdpx.config-fingerprint" }}' \
            "$CONTAINER_NAME" 2>/dev/null || true)
    fi
    if [ "$current_image" != "$IMAGE_REF" ] || [ "$current_fingerprint" != "$fingerprint" ]; then
        active=$(container_active_count)
        if [ "$active" != "0" ]; then
            usage_error "runtime update pending with $active active session(s); stop them or run cdpx runtime reset --force"
        fi
        remove_runtime_container
    fi
    if ! container_exists; then
        runtime_id=$(sha256_text "$WORKSPACE:$fingerprint:$IMAGE_REF:$(date +%s)")
        idle_timeout=$(sed -n '1p' "$PLAN_DIR/idle-timeout")
        set -- run --detach \
            --name "$CONTAINER_NAME" \
            --label "io.cdpx.workspace=$WORKSPACE" \
            --label "io.cdpx.uid=$USER_ID" \
            --label "io.cdpx.image=$IMAGE_REF" \
            --label "io.cdpx.runtime-id=$runtime_id" \
            --label "io.cdpx.config-fingerprint=$fingerprint" \
            --user "$USER_ID:$GROUP_ID" \
            --read-only \
            --security-opt no-new-privileges \
            --cap-drop ALL \
            --tmpfs /tmp:rw,nosuid,nodev,noexec,size=256m \
            --mount "type=bind,source=$WORKSPACE,target=$WORKSPACE" \
            --workdir "$CURRENT_DIRECTORY" \
            --env "CDPX_RUNTIME_ID=$runtime_id" \
            --env "CDPX_WORKSPACE=$WORKSPACE" \
            --env "CDPX_IMAGE_REF=$IMAGE_REF" \
            --env "CDPX_CONTAINERIZED=1" \
            --env "XDG_RUNTIME_DIR=$STATE_DIR" \
            --env "HOME=$STATE_DIR/home" \
            --entrypoint python
        while IFS= read -r argument; do
            [ -n "$argument" ] && set -- "$@" "$argument"
        done < "$PLAN_DIR/docker.args"
        set -- "$@" "$IMAGE_REF" -m cdpx.runtime guardian --idle-timeout "$idle_timeout"
        docker "$@" >/dev/null
    elif ! container_running; then
        docker start "$CONTAINER_NAME" >/dev/null
    fi
}

append_environment() {
    name=$1
    required=$2
    eval "value=\${$name-}"
    if [ "$required" = "yes" ] && [ -z "$value" ]; then
        usage_error "required environment variable is missing or empty: $name"
    fi
    if [ -n "$value" ]; then
        printf '%s=%s\n' "$name" "$value" >> "$EXEC_ENV"
    fi
}

build_exec_environment() {
    EXEC_ENV=$(mktemp "$STATE_DIR/exec-env.XXXXXX")
    chmod 600 "$EXEC_ENV"
    while IFS= read -r line; do
        [ -n "$line" ] && printf '%s\n' "$line" >> "$EXEC_ENV"
    done < "$PLAN_DIR/environment.set"
    while IFS= read -r name; do
        [ -n "$name" ] && append_environment "$name" yes
    done < "$PLAN_DIR/environment.required"
    while IFS= read -r name; do
        [ -n "$name" ] && append_environment "$name" no
    done < "$PLAN_DIR/environment.optional"
    for name in CDPX_SESSION CDPX_RUN_ID CDPX_TARGET CDPX_ORIGINS; do
        append_environment "$name" no
    done
}

runtime_status() {
    if ! container_exists; then
        printf '{"schema":"cdpx.runtime/v1","workspace":"%s","running":false,"active_sessions":0}\n' \
            "$(json_escape "$WORKSPACE")"
        return
    fi
    if ! container_running; then
        printf '{"schema":"cdpx.runtime/v1","workspace":"%s","running":false,"active_sessions":0,"container":"%s"}\n' \
            "$(json_escape "$WORKSPACE")" "$CONTAINER_NAME"
        return
    fi
    docker exec "$CONTAINER_NAME" python -m cdpx.runtime status
}

runtime_command() {
    action=${1:-}
    shift || true
    case "$action" in
        plan)
            [ "$#" -eq 0 ] || usage_error "runtime plan accepts no arguments"
            cat "$PLAN_DIR/plan.json"
            ;;
        status)
            [ "$#" -eq 0 ] || usage_error "runtime status accepts no arguments"
            runtime_status
            ;;
        stop)
            force=no
            if [ "${1:-}" = "--force" ]; then
                force=yes
                shift
            fi
            [ "$#" -eq 0 ] || usage_error "usage: cdpx runtime stop [--force]"
            active=$(container_active_count)
            if [ "$active" != "0" ] && [ "$force" != "yes" ]; then
                usage_error "runtime has $active active session(s); use --force"
            fi
            remove_runtime_container
            printf '{"stopped":true,"container":"%s","forced":%s}\n' \
                "$CONTAINER_NAME" "$( [ "$force" = yes ] && printf true || printf false )"
            ;;
        reset)
            if [ "${1:-}" != "--force" ] || [ "$#" -ne 1 ]; then
                usage_error "usage: cdpx runtime reset --force"
            fi
            remove_runtime_container
            rm -rf "$STATE_DIR"
            printf '{"reset":true,"container":"%s"}\n' "$CONTAINER_NAME"
            ;;
        *)
            usage_error "runtime supports: plan, status, stop, reset"
            ;;
    esac
}

update_launcher() {
    version=""
    if [ "${1:-}" = "--version" ]; then
        [ "$#" -eq 2 ] || usage_error "usage: cdpx update [--version vX.Y.Z]"
        version=$2
    elif [ "$#" -ne 0 ]; then
        usage_error "usage: cdpx update [--version vX.Y.Z]"
    fi
    temporary=$(mktemp "${TMPDIR:-/tmp}/cdpx-install.XXXXXX")
    trap 'rm -f "$temporary" "${EXEC_ENV:-}"' EXIT HUP INT TERM
    command -v curl >/dev/null 2>&1 || die "curl is required for update"
    curl -fsSL "$INSTALL_URL" -o "$temporary"
    chmod 700 "$temporary"
    if [ -n "$version" ]; then
        "$temporary" --version "$version"
    else
        "$temporary"
    fi
}

docker_ready
WORKSPACE=$(workspace_root)
CURRENT_DIRECTORY=$(pwd -P)
USER_ID=$(id -u)
GROUP_ID=$(id -g)
workspace_hash=$(sha256_text "$WORKSPACE")
CONTAINER_NAME="cdpx-$USER_ID-$(printf '%.16s' "$workspace_hash")"
STATE_DIR="$WORKSPACE/.cdpx/runtime"
PLAN_DIR="$STATE_DIR/plan"
IMAGE_REF=$(image_ref)
mkdir -p "$STATE_DIR"
chmod 700 "$WORKSPACE/.cdpx" "$STATE_DIR"

case "${1:-}" in
    --version)
        [ "$#" -eq 1 ] || usage_error "--version accepts no other argument"
        runtime_version=""
        if container_exists; then
            runtime_version=$(docker inspect --format '{{ index .Config.Labels "org.opencontainers.image.version" }}' \
                "$CONTAINER_NAME" 2>/dev/null || true)
        fi
        printf '{"launcher_version":"%s","runtime_version":"%s","image":"%s"}\n' \
            "$LAUNCHER_VERSION" "$(json_escape "$runtime_version")" "$(json_escape "$IMAGE_REF")"
        exit 0
        ;;
    update)
        shift
        update_launcher "$@"
        exit 0
        ;;
esac

compile_plan

case "${1:-}" in
    init)
        [ "$#" -eq 1 ] || usage_error "cdpx init accepts no arguments"
        docker run --rm \
            --user "$USER_ID:$GROUP_ID" \
            --mount "type=bind,source=$WORKSPACE,target=$WORKSPACE" \
            --workdir "$WORKSPACE" \
            --entrypoint python \
            "$IMAGE_REF" -m cdpx.runtime_config init --root "$WORKSPACE"
        exit $?
        ;;
    runtime)
        shift
        runtime_command "$@"
        exit $?
        ;;
esac

ensure_runtime
build_exec_environment
trap 'rm -f "$EXEC_ENV"' EXIT HUP INT TERM
docker exec \
    --workdir "$CURRENT_DIRECTORY" \
    --env-file "$EXEC_ENV" \
    "$CONTAINER_NAME" \
    cdpx "$@"
